-- Auto Clean Job — Street Life Remastered v1

local Config = {
    Enabled = false,
    TweenSpeed = 0.55,
    ArriveDelay = 0.25,
    CleanWaitMax = 3.0,
    CleanCheckRate = 0.05,
    InteractDelay = 0.3,
    PollRate = 0.8,
    TotalPuddles = 8,
}

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local ppOffset = nil
local cfOffsets = nil

-- Load Offsets
task.spawn(function()
    local ok, res = pcall(game.HttpGet, game, "https://offsets.ntgetwritewatch.workers.dev/offsets.json")
    if ok and res then
        local dok, data = pcall(HttpService.JSONDecode, HttpService, res)
        if dok and data then
            if data.ProximityPromptHoldDuraction then
                ppOffset = tonumber(data.ProximityPromptHoldDuraction, 16)
            end
            if data.Primitive and data.CFrame and data.Velocity then
                cfOffsets = data
            end
        end
    end
end)

local function getHRP()
    local lp = Players.LocalPlayer
    if not lp or not lp.Character then return nil end
    return lp.Character:FindFirstChild("HumanoidRootPart")
end

local function pressE()
    keypress(0x45)
    task.wait(0.05)
    keyrelease(0x45)
end

local function zeroPrompt(prompt)
    if not ppOffset or not prompt then return end
    pcall(memory_write, "float", prompt.Address + ppOffset, 0)
end

local function dist3D(a, b)
    if not a or not b then return math.huge end
    local dx = b.X - a.X
    local dy = b.Y - a.Y
    local dz = b.Z - a.Z
    return math.sqrt(dx*dx + dy*dy + dz*dz)
end

-- Optimized Tween
local function tweenTo(targetPos, speed)
    if not cfOffsets then
        notify("Offsets not loaded yet!", "Clean Job", 3)
        return false
    end
    local hrp = getHRP()
    if not hrp then return false end

    local okP, prim = pcall(memory_read, "uintptr", hrp.Address + cfOffsets.Primitive)
    if not okP or not prim or prim <= 4096 then return false end

    local cf = cfOffsets.CFrame
    local vel = cfOffsets.Velocity

    local ex, ey, ez = targetPos.X, targetPos.Y + 3.5, targetPos.Z

    local function writePos(px, py, pz)
        pcall(function()
            memory_write("float", prim + cf + 0x00, 1)
            memory_write("float", prim + cf + 0x04, 0)
            memory_write("float", prim + cf + 0x08, 0)
            memory_write("float", prim + cf + 0x0C, 0)
            memory_write("float", prim + cf + 0x10, 1)
            memory_write("float", prim + cf + 0x14, 0)
            memory_write("float", prim + cf + 0x18, 0)
            memory_write("float", prim + cf + 0x1C, 0)
            memory_write("float", prim + cf + 0x20, 1)
            memory_write("float", prim + cf + 0x24, px)
            memory_write("float", prim + cf + 0x28, py)
            memory_write("float", prim + cf + 0x2C, pz)
            memory_write("float", prim + vel, 0)
            memory_write("float", prim + vel + 4, 0)
            memory_write("float", prim + vel + 8, 0)
        end)
    end

    if speed <= 0 then
        writePos(ex, ey, ez)
        return true
    end

    local okX, sx = pcall(memory_read, "float", prim + cf + 0x24)
    local okY, sy = pcall(memory_read, "float", prim + cf + 0x28)
    local okZ, sz = pcall(memory_read, "float", prim + cf + 0x2C)

    if not (okX and okY and okZ) then
        writePos(ex, ey, ez)
        return true
    end

    local t0 = os.clock()
    while os.clock() - t0 < speed do
        local t = math.min((os.clock() - t0) / speed, 1)
        local ep = 1 - (1 - t) ^ 3
        writePos(
            sx + (ex - sx) * ep,
            sy + (ey - sy) * ep,
            sz + (ez - sz) * ep
        )
        task.wait(0.016)
    end
    writePos(ex, ey, ez)
    return true
end

local function isCleanable(part)
    if not part or not part.Parent then return false end
    local prompt = part:FindFirstChildOfClass("ProximityPrompt")
    if not prompt then return false end
    local okE, enabled = pcall(function() return prompt.Enabled end)
    if okE and enabled == false then return false end
    local okT, trans = pcall(function() return part.Transparency end)
    if okT and trans and trans >= 1 then return false end
    return true
end

local function cleanAndWait(part)
    local prompt = part:FindFirstChildOfClass("ProximityPrompt")
    if prompt then zeroPrompt(prompt) end
    pressE()

    local t0 = os.clock()
    while os.clock() - t0 < Config.CleanWaitMax do
        task.wait(Config.CleanCheckRate)
        if not isCleanable(part) then
            task.wait(Config.InteractDelay)
            return true
        end
        if (os.clock() - t0) % 0.5 < Config.CleanCheckRate then
            pressE()
        end
    end
    return not isCleanable(part)
end

local function getActivePuddles()
    local cleanFolder
    pcall(function()
        cleanFolder = workspace.Map.Jobs.CleanNPC.Clean
    end)
    if not cleanFolder then return {} end

    local hrp = getHRP()
    local myPos = hrp and hrp.Position
    local puddles = {}

    for i = 1, Config.TotalPuddles do
        local part = cleanFolder:FindFirstChild(tostring(i))
        if part and isCleanable(part) then
            local okPos, pos = pcall(function() return part.Position end)
            if okPos and pos then
                local d = myPos and dist3D(myPos, pos) or 9999
                table.insert(puddles, {part = part, pos = pos, dist = d})
            end
        end
    end

    table.sort(puddles, function(a, b) return a.dist < b.dist end)
    return puddles
end

-- Main Loop
local running = true
task.spawn(function()
    while running do
        task.wait(Config.PollRate)
        if not Config.Enabled then continue end

        local puddles = getActivePuddles()
        if #puddles == 0 then continue end

        for _, entry in ipairs(puddles) do
            if not Config.Enabled then break end
            if not isCleanable(entry.part) then continue end

            local success = tweenTo(entry.pos, Config.TweenSpeed)
            if not success then continue end

            task.wait(Config.ArriveDelay)
            if not isCleanable(entry.part) then continue end

            cleanAndWait(entry.part)
        end
    end
end)

-- Keybind (J)
local keybindVK = 0x4A
local lastPressed = false
task.spawn(function()
    while running do
        task.wait(0.05)
        local pressed = iskeypressed(keybindVK)
        if pressed and not lastPressed then
            Config.Enabled = not Config.Enabled
            UI.SetValue("cj_enabled", Config.Enabled)
            notify(Config.Enabled and "Auto Clean ON" or "Auto Clean OFF", "Clean Job", 2)
        end
        lastPressed = pressed
    end
end)

-- UI
UI.AddTab("Clean Job", function(tab)
    local sec = tab:Section("Settings", "Left")
    sec:Toggle("cj_enabled", "Enable Auto Clean", Config.Enabled, function(val)
        Config.Enabled = val
    end)
    sec:SliderFloat("cj_speed", "Tween Speed (seconds)", 0.1, 1.5, Config.TweenSpeed, "%.2f", function(val)
        Config.TweenSpeed = val
    end)
    sec:SliderFloat("cj_arrive", "Arrive Delay (s)", 0.0, 1.0, Config.ArriveDelay, "%.2f", function(val)
        Config.ArriveDelay = val
    end)
    sec:SliderFloat("cj_cleanwait", "Clean Wait Max (s)", 0.5, 6.0, Config.CleanWaitMax, "%.1f", function(val)
        Config.CleanWaitMax = val
    end)
    sec:SliderFloat("cj_after", "After Clean Delay (s)", 0.0, 1.0, Config.InteractDelay, "%.2f", function(val)
        Config.InteractDelay = val
    end)

    local sec2 = tab:Section("Misc", "Right")
    sec2:Text("Toggle Key: J")
    sec2:Spacing()
    sec2:Button("Check Puddles Now", function()
        local p = getActivePuddles()
        notify(#p .. " / " .. Config.TotalPuddles .. " puddles available", "Clean Job", 3)
    end)
end)

notify("Auto Clean Job v1 loaded! Press J to toggle.", "Street Life", 3)

while running do task.wait(60) end
